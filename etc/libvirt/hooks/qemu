#!/bin/bash
# libvirt qemu hook for bazzite VM.
# Host boots with amdgpu owning 6800 XT.
# VM start: bind GPU functions to vfio-pci and hand off BT USB exclusively.
# VM stop: reclaim GPU back to host drivers without reboot.

set -u

GUEST="$1"
OPERATION="$2"
SUBOP="${3:-}"

[ "$GUEST" = "bazzite" ] || exit 0

LOG=/var/log/libvirt-hooks.log
STATE_ROOT=/run/libvirt/hook-state
STATE_DIR="$STATE_ROOT/$GUEST"
LOCK_FILE="$STATE_ROOT/$GUEST.lock"
PREPARED="$STATE_DIR/prepared"
STARTED="$STATE_DIR/started"
PREV_GOV="$STATE_DIR/prev_governor"
BT_IFACES="$STATE_DIR/bt-ifaces"

HOST_CPUS="0-3,10-13"
FULL_CPUS="0-19"
GPU_FUNCS=(0000:03:00.0 0000:03:00.1 0000:03:00.2 0000:03:00.3)
BT_VENDOR_ID="8087"
BT_PRODUCT_ID="0026"

mkdir -p "$STATE_DIR"
exec >>"$LOG" 2>&1
echo "[$(date '+%F %T')] hook: $OPERATION/$SUBOP"

exec 9>"$LOCK_FILE"
if ! flock -w 60 9; then
    echo "[$(date +%T)] ABORT: failed to acquire hook lock"
    exit 1
fi

log() {
    echo "[$(date +%T)] $*"
}

driver_for() {
    local func="$1"
    local drv_link
    drv_link=$(readlink "/sys/bus/pci/devices/$func/driver" 2>/dev/null || true)
    if [ -n "$drv_link" ]; then
        basename "$drv_link"
    else
        echo "NONE"
    fi
}

gpu_on_vfio() {
    [ "$(driver_for 0000:03:00.0)" = "vfio-pci" ]
}

set_runtime_cpus() {
    local cpus="$1"
    systemctl set-property --runtime -- system.slice AllowedCPUs="$cpus" 2>/dev/null || true
    systemctl set-property --runtime -- user.slice   AllowedCPUs="$cpus" 2>/dev/null || true
    systemctl set-property --runtime -- init.scope   AllowedCPUs="$cpus" 2>/dev/null || true
}

restore_governor() {
    local prev
    prev=$(cat "$PREV_GOV" 2>/dev/null || echo powersave)
    for g in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do
        echo "$prev" > "$g" 2>/dev/null || true
    done
}

check_gpu_busy() {
    local busy=""
    if [ -e /dev/kfd ]; then
        local pids
        local comm
        pids=$(fuser /dev/kfd 2>/dev/null || true)
        for p in $pids; do
            [ -r "/proc/$p/comm" ] || continue
            comm=$(cat "/proc/$p/comm")
            case "$comm" in
                systemd|systemd-logind|kwin_wayland|Xwayland|Xorg|plasmashell|sddm|sddm-helper) ;;
                *) busy="$busy $p($comm)" ;;
            esac
        done
    fi
    echo "$busy"
}

vm_has_bt_usb_hostdev() {
    local xml_file="/etc/libvirt/qemu/${GUEST}.xml"

    [ -r "$xml_file" ] || return 1

    grep -Eiq "<vendor[[:space:]]+id=['\"]0x$BT_VENDOR_ID['\"]" "$xml_file" || return 1
    grep -Eiq "<product[[:space:]]+id=['\"]0x$BT_PRODUCT_ID['\"]" "$xml_file" || return 1
    return 0
}

list_bt_usb_devices() {
    local dev vid pid
    for dev in /sys/bus/usb/devices/*; do
        [ -r "$dev/idVendor" ] || continue
        [ -r "$dev/idProduct" ] || continue
        vid=$(cat "$dev/idVendor" 2>/dev/null || true)
        pid=$(cat "$dev/idProduct" 2>/dev/null || true)
        if [ "$vid" = "$BT_VENDOR_ID" ] && [ "$pid" = "$BT_PRODUCT_ID" ]; then
            basename "$dev"
        fi
    done
}

bt_handoff_prepare() {
    local devices
    local dev iface cur iface_name dev_path

    devices=$(list_bt_usb_devices | xargs)
    rm -f "$BT_IFACES"

    if ! vm_has_bt_usb_hostdev; then
        return 0
    fi

    if [ -z "$devices" ]; then
        log "bt handoff: adapter ${BT_VENDOR_ID}:${BT_PRODUCT_ID} not present on host"
        return 0
    fi

    # Prime Intel BT firmware once on the host stack before passthrough.
    # This does not touch Wi-Fi state.
    systemctl start bluetooth.service 2>/dev/null || true
    if command -v bluetoothctl >/dev/null 2>&1; then
        timeout 6 bluetoothctl power on >/dev/null 2>&1 || true
    fi

    systemctl stop bluetooth.service 2>/dev/null || true
    systemctl stop bluetooth.target 2>/dev/null || true

    for dev in $devices; do
        dev_path="/sys/bus/usb/devices/$dev"

        if [ -e "$dev_path/power/control" ]; then
            echo on > "$dev_path/power/control" 2>/dev/null || true
        fi
        if [ -e "$dev_path/power/autosuspend_delay_ms" ]; then
            echo -1 > "$dev_path/power/autosuspend_delay_ms" 2>/dev/null || true
        fi
        if [ -e "$dev_path/authorized" ]; then
            echo 0 > "$dev_path/authorized" 2>/dev/null || true
            sleep 1
            echo 1 > "$dev_path/authorized" 2>/dev/null || true
        fi

        for iface in "/sys/bus/usb/devices/$dev":*; do
            [ -e "$iface" ] || continue
            [ -L "$iface/driver" ] || continue
            cur=$(basename "$(readlink "$iface/driver")")
            iface_name=${iface##*/}
            if [ "$cur" = "btusb" ]; then
                log "bt handoff: unbind $iface_name from btusb"
                echo "$iface_name" > /sys/bus/usb/drivers/btusb/unbind 2>/dev/null || true
                echo "$iface_name" >> "$BT_IFACES"
            fi
        done
    done

    if [ -s "$BT_IFACES" ]; then
        sort -u -o "$BT_IFACES" "$BT_IFACES" 2>/dev/null || true
        log "bt handoff: interfaces released to VM"
    else
        log "bt handoff: no btusb interfaces needed unbind"
    fi
}

bt_handoff_release() {
    local iface

    if ! vm_has_bt_usb_hostdev; then
        return 0
    fi

    if [ -s "$BT_IFACES" ]; then
        while read -r iface; do
            [ -n "$iface" ] || continue
            log "bt restore: bind $iface to btusb"
            echo "$iface" > /sys/bus/usb/drivers/btusb/bind 2>/dev/null || true
        done < "$BT_IFACES"
    fi

    rm -f "$BT_IFACES"
    systemctl start bluetooth.service 2>/dev/null || true
}

bind_gpu_to_vfio() {
    local f
    local cur_drv

    for f in "${GPU_FUNCS[@]}"; do
        cur_drv=$(driver_for "$f")
        if [ "$cur_drv" != "vfio-pci" ]; then
            log "setting driver_override=vfio-pci on $f (current: $cur_drv)"
            echo vfio-pci > "/sys/bus/pci/devices/$f/driver_override"
            if [ "$cur_drv" != "NONE" ]; then
                log "unbind $f from $cur_drv"
                echo "$f" > "/sys/bus/pci/drivers/$cur_drv/unbind" 2>/dev/null || {
                    log "CRITICAL: failed to unbind $f from $cur_drv"
                    return 1
                }
            fi
            log "bind $f to vfio-pci"
            echo "$f" > /sys/bus/pci/drivers/vfio-pci/bind 2>/dev/null || true
        fi
    done

    for f in "${GPU_FUNCS[@]}"; do
        log "[$f] driver=$(driver_for "$f")"
    done

    if [ "$(driver_for 0000:03:00.0)" != "vfio-pci" ]; then
        log "CRITICAL: 03:00.0 is $(driver_for 0000:03:00.0), expected vfio-pci"
        return 1
    fi

    return 0
}

prepare_begin() {
    local busy

    cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor > "$PREV_GOV" 2>/dev/null || echo powersave > "$PREV_GOV"
    for g in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do
        echo performance > "$g" 2>/dev/null || true
    done

    busy=$(check_gpu_busy)
    busy=$(echo "$busy" | xargs)
    if [ -n "$busy" ]; then
        log "ABORT: GPU busy with non-display processes: $busy"
        log "Stop ollama/rocm/stable-diffusion and retry"
        return 1
    fi

    sddm_xorg_pid=$(pgrep -f "Xorg.*seat0.*vt2" || true)
    if [ -n "$sddm_xorg_pid" ]; then
        log "stopping SDDM greeter Xorg (PID $sddm_xorg_pid)"
        kill -TERM "$sddm_xorg_pid" 2>/dev/null || true
        for _ in $(seq 1 10); do
            kill -0 "$sddm_xorg_pid" 2>/dev/null || break
            sleep 0.3
        done
    fi

    modprobe vfio 2>/dev/null || true
    modprobe vfio_iommu_type1 2>/dev/null || true
    modprobe vfio-pci 2>/dev/null || true

    bind_gpu_to_vfio || return 1

    modprobe -r amdxcp drm_ttm_helper drm_suballoc_helper drm_buddy 2>/dev/null || true
    modprobe -r amdgpu 2>/dev/null || true

    if ! grep -q '^amdgpu ' /proc/modules 2>/dev/null; then
        log "amdgpu module fully unloaded for clean reclaim"
    else
        log "WARNING: amdgpu still loaded after prepare; deferred worker will retry unload"
    fi

    set_runtime_cpus "$HOST_CPUS"

    bt_handoff_prepare

    touch "$PREPARED"
    rm -f "$STARTED"
    log "prepare complete - 6800 XT is on vfio-pci"
    return 0
}

started_begin() {
    touch "$STARTED"
    log "started marker set"
}

release_end() {
    set_runtime_cpus "$FULL_CPUS"
    restore_governor

    if gpu_on_vfio; then
        log "queueing deferred GPU reclaim worker"
        if command -v systemd-run >/dev/null 2>&1; then
            systemd-run --unit "vfio-reclaim-${GUEST}-$(date +%s)" --collect --quiet \
                /usr/local/sbin/vfio-gpu-reclaim "$GUEST" >/dev/null 2>&1 || true
        else
            /usr/local/sbin/vfio-gpu-reclaim "$GUEST" >/dev/null 2>&1 &
        fi
    else
        log "release: GPU already on host driver ($(driver_for 0000:03:00.0))"
    fi

    bt_handoff_release

    rm -f "$PREPARED" "$STARTED"
    log "release complete"
}

case "$OPERATION/$SUBOP" in
    prepare/begin) prepare_begin || exit 1 ;;
    started/begin) started_begin ;;
    release/end)   release_end ;;
    *) ;;
esac
